{
  "openapi": "3.0.0",
  "info": {
    "title": "Working Service API",
    "description": "REST API for background task execution and management",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/services/working/api",
      "description": "Working Service API"
    }
  ],
  "paths": {
    "/run": {
      "post": {
        "summary": "Run a background task",
        "description": "Runs a new background task with the specified script and data",
        "tags": ["Task Execution"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "task": {
                    "type": "string",
                    "description": "Path to the task script file"
                  },
                  "data": {
                    "type": "object",
                    "description": "Optional data to pass to the task"
                  }
                },
                "example": {
                  "task": "/path/to/task.js",
                  "data": {
                    "key": "value"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task started successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pid": {
                      "type": "number",
                      "description": "Process ID of the running task"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing task path"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/stop": {
      "get": {
        "summary": "Stop a background task",
        "description": "Stops the currently running background task",
        "tags": ["Task Execution"],
        "responses": {
          "200": {
            "description": "Task stopped successfully",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "OK"
                }
              }
            }
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/status": {
      "get": {
        "summary": "Service status",
        "description": "Check if the working service is running",
        "tags": ["Service Status"],
        "responses": {
          "200": {
            "description": "Service is running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "example": "working api running"
                }
              }
            }
          }
        }
      }
    },
    "/analytics": {
      "get": {
        "summary": "Get all tasks analytics",
        "description": "Retrieves analytics for all executed tasks",
        "tags": ["Analytics"],
        "responses": {
          "200": {
            "description": "Tasks analytics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "integer",
                      "description": "Number of tasks"
                    },
                    "tasks": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Analytics module not available"
          }
        }
      }
    },
    "/stats": {
      "get": {
        "summary": "Get overall task statistics",
        "description": "Retrieves overall statistics about task executions",
        "tags": ["Analytics"],
        "responses": {
          "200": {
            "description": "Overall statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": {
                      "type": "integer",
                      "description": "Total number of task executions"
                    },
                    "counts": {
                      "type": "object",
                      "properties": {
                        "completed": {
                          "type": "integer"
                        },
                        "errors": {
                          "type": "integer"
                        },
                        "active": {
                          "type": "integer"
                        }
                      }
                    },
                    "percentages": {
                      "type": "object",
                      "properties": {
                        "completed": {
                          "type": "number"
                        },
                        "errors": {
                          "type": "number"
                        },
                        "active": {
                          "type": "number"
                        }
                      }
                    },
                    "lastRun": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp of the last task execution"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Analytics module not available"
          }
        }
      }
    },
    "/settings": {
      "get": {
        "summary": "Get working service settings",
        "description": "Retrieves the working service configuration settings",
        "tags": ["Settings"],
        "responses": {
          "200": {
            "description": "Service settings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "description": "Failed to retrieve settings"
          }
        }
      },
      "post": {
        "summary": "Save working service settings",
        "description": "Updates the working service configuration settings",
        "tags": ["Settings"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "maxConcurrentTasks": {
                    "type": "number",
                    "description": "Maximum number of concurrent tasks"
                  },
                  "taskTimeout": {
                    "type": "number",
                    "description": "Task timeout in milliseconds"
                  },
                  "enableQueuing": {
                    "type": "boolean",
                    "description": "Whether to enable task queuing"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings saved successfully"
          },
          "400": {
            "description": "Bad request - missing settings"
          },
          "500": {
            "description": "Failed to save settings"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Task Execution",
      "description": "Operations for executing and managing background tasks"
    },
    {
      "name": "Analytics",
      "description": "Analytics and reporting operations"
    },
    {
      "name": "Settings",
      "description": "Service configuration and settings"
    },
    {
      "name": "Service Status",
      "description": "Service status and health checks"
    }
  ]
}
