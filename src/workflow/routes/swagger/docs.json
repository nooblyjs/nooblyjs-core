{
  "openapi": "3.0.0",
  "info": {
    "title": "Workflow Service API",
    "description": "REST API for defining, managing, and executing workflows with full execution tracking and statistics",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/services/workflow/api",
      "description": "Workflow Service API"
    }
  ],
  "paths": {
    "/defineworkflow": {
      "post": {
        "summary": "Define a new workflow",
        "description": "Creates a new workflow definition with a name and array of steps",
        "tags": ["Workflow Definition"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "steps"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Unique name for the workflow"
                  },
                  "steps": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of step file paths"
                  },
                  "metadata": {
                    "type": "object",
                    "properties": {
                      "description": {
                        "type": "string",
                        "description": "Description of the workflow"
                      },
                      "tags": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "Tags for categorization"
                      }
                    }
                  }
                }
              },
              "example": {
                "name": "order-processing",
                "steps": ["steps/validate.js", "steps/charge.js", "steps/confirm.js"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow defined successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "workflowId": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing workflow name"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/start": {
      "post": {
        "summary": "Start a workflow execution",
        "description": "Executes a defined workflow with optional input data",
        "tags": ["Workflow Execution"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Name of the workflow to execute"
                  },
                  "data": {
                    "type": "object",
                    "description": "Optional input data for the workflow"
                  }
                }
              },
              "example": {
                "name": "order-processing",
                "data": {
                  "orderId": 12345
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow started successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "workflowId": {
                      "type": "string",
                      "description": "Unique execution ID"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing workflow name"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/status": {
      "get": {
        "summary": "Service status",
        "description": "Check if the workflow service is running",
        "tags": ["Service Status"],
        "responses": {
          "200": {
            "description": "Service is running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "example": "workflow api running"
                }
              }
            }
          }
        }
      }
    },
    "/definitions": {
      "get": {
        "summary": "List all workflow definitions",
        "description": "Retrieves all defined workflow definitions with metadata",
        "tags": ["Workflow Definition"],
        "responses": {
          "200": {
            "description": "List of all workflow definitions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "integer"
                    },
                    "definitions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/WorkflowDefinition"
                      }
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Definition container not available"
          }
        }
      }
    },
    "/definitions/{workflowName}": {
      "get": {
        "summary": "Get a specific workflow definition",
        "description": "Retrieves a single workflow definition by name",
        "tags": ["Workflow Definition"],
        "parameters": [
          {
            "name": "workflowName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the workflow"
          }
        ],
        "responses": {
          "200": {
            "description": "Workflow definition",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowDefinition"
                }
              }
            }
          },
          "404": {
            "description": "Workflow definition not found"
          },
          "503": {
            "description": "Definition container not available"
          }
        }
      },
      "put": {
        "summary": "Update a workflow definition",
        "description": "Updates the steps and/or metadata of an existing workflow",
        "tags": ["Workflow Definition"],
        "parameters": [
          {
            "name": "workflowName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the workflow to update"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "steps": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "New array of step file paths"
                  },
                  "metadata": {
                    "type": "object",
                    "properties": {
                      "description": {
                        "type": "string"
                      },
                      "tags": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowDefinition"
                }
              }
            }
          },
          "404": {
            "description": "Workflow definition not found"
          },
          "503": {
            "description": "Definition container not available"
          }
        }
      },
      "delete": {
        "summary": "Delete a workflow definition",
        "description": "Deletes a workflow definition by name",
        "tags": ["Workflow Definition"],
        "parameters": [
          {
            "name": "workflowName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the workflow to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Workflow deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    },
                    "workflowName": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Workflow definition not found"
          },
          "503": {
            "description": "Definition container not available"
          }
        }
      }
    },
    "/executions/{workflowName}": {
      "get": {
        "summary": "Get execution history for a workflow",
        "description": "Retrieves execution history for a specific workflow with filtering and pagination",
        "tags": ["Workflow Execution"],
        "parameters": [
          {
            "name": "workflowName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the workflow"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["completed", "running", "error"]
            },
            "description": "Filter by execution status"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            },
            "description": "Maximum number of results"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Execution history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "workflowName": {
                      "type": "string"
                    },
                    "executions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ExecutionRecord"
                      }
                    },
                    "total": {
                      "type": "integer"
                    },
                    "limit": {
                      "type": "integer"
                    },
                    "offset": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Execution container not available"
          }
        }
      },
      "delete": {
        "summary": "Delete old executions",
        "description": "Deletes workflow executions based on age and/or status",
        "tags": ["Workflow Execution"],
        "parameters": [
          {
            "name": "workflowName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the workflow"
          },
          {
            "name": "older_than",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "ISO timestamp - delete executions older than this"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["completed", "running", "error"]
            },
            "description": "Delete only executions with this status"
          }
        ],
        "responses": {
          "200": {
            "description": "Executions deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    },
                    "workflowName": {
                      "type": "string"
                    },
                    "deleted": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Execution container not available"
          }
        }
      }
    },
    "/executions/{workflowName}/execution/{executionId}": {
      "get": {
        "summary": "Get specific execution details",
        "description": "Retrieves detailed information about a specific workflow execution",
        "tags": ["Workflow Execution"],
        "parameters": [
          {
            "name": "workflowName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the workflow"
          },
          {
            "name": "executionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique execution ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Execution details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecutionRecord"
                }
              }
            }
          },
          "404": {
            "description": "Execution not found"
          },
          "503": {
            "description": "Execution container not available"
          }
        }
      }
    },
    "/executions/{workflowName}/stats": {
      "get": {
        "summary": "Get execution statistics",
        "description": "Retrieves statistics about workflow executions",
        "tags": ["Workflow Execution"],
        "parameters": [
          {
            "name": "workflowName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the workflow"
          }
        ],
        "responses": {
          "200": {
            "description": "Execution statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "workflowName": {
                      "type": "string"
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total number of executions"
                    },
                    "completed": {
                      "type": "integer",
                      "description": "Number of completed executions"
                    },
                    "running": {
                      "type": "integer",
                      "description": "Number of running executions"
                    },
                    "error": {
                      "type": "integer",
                      "description": "Number of failed executions"
                    },
                    "averageDuration": {
                      "type": "number",
                      "description": "Average execution duration in milliseconds"
                    },
                    "lastExecution": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp of last execution"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Execution container not available"
          }
        }
      }
    },
    "/analytics": {
      "get": {
        "summary": "Get all workflows analytics",
        "description": "Retrieves analytics for all workflows",
        "tags": ["Analytics"],
        "responses": {
          "200": {
            "description": "Workflows analytics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "integer"
                    },
                    "workflows": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Analytics module not available"
          }
        }
      }
    },
    "/analytics/{workflowName}": {
      "get": {
        "summary": "Get specific workflow analytics",
        "description": "Retrieves analytics for a specific workflow",
        "tags": ["Analytics"],
        "parameters": [
          {
            "name": "workflowName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the workflow"
          }
        ],
        "responses": {
          "200": {
            "description": "Workflow analytics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Workflow not found"
          },
          "503": {
            "description": "Analytics module not available"
          }
        }
      }
    },
    "/stats": {
      "get": {
        "summary": "Get overall workflow statistics",
        "description": "Retrieves overall statistics about workflow executions",
        "tags": ["Analytics"],
        "responses": {
          "200": {
            "description": "Overall statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "503": {
            "description": "Analytics module not available"
          }
        }
      }
    },
    "/settings": {
      "get": {
        "summary": "Get workflow service settings",
        "description": "Retrieves the workflow service configuration settings",
        "tags": ["Settings"],
        "responses": {
          "200": {
            "description": "Service settings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "description": "Failed to retrieve settings"
          }
        }
      },
      "post": {
        "summary": "Save workflow service settings",
        "description": "Updates the workflow service configuration settings",
        "tags": ["Settings"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "maxSteps": {
                    "type": "number",
                    "description": "Maximum number of steps in a workflow"
                  },
                  "timeoutPerStep": {
                    "type": "number",
                    "description": "Timeout per step in milliseconds"
                  },
                  "parallelExecution": {
                    "type": "boolean",
                    "description": "Whether to enable parallel step execution"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings saved successfully"
          },
          "400": {
            "description": "Bad request - missing settings"
          },
          "500": {
            "description": "Failed to save settings"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WorkflowDefinition": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique name of the workflow"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of step file paths"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string",
                "description": "Description of the workflow"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Tags for categorization"
              },
              "createdAt": {
                "type": "string",
                "format": "date-time",
                "description": "Creation timestamp"
              },
              "updatedAt": {
                "type": "string",
                "format": "date-time",
                "description": "Last update timestamp"
              },
              "version": {
                "type": "integer",
                "description": "Version number (incremented on updates)"
              }
            }
          }
        }
      },
      "ExecutionRecord": {
        "type": "object",
        "properties": {
          "executionId": {
            "type": "string",
            "description": "Unique execution ID"
          },
          "workflowName": {
            "type": "string",
            "description": "Name of the executed workflow"
          },
          "inputData": {
            "type": "object",
            "description": "Input data provided to the workflow"
          },
          "outputData": {
            "type": "object",
            "description": "Output data from the workflow"
          },
          "status": {
            "type": "string",
            "enum": ["completed", "running", "error"],
            "description": "Current execution status"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Execution start time"
          },
          "endedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Execution end time"
          },
          "duration": {
            "type": "integer",
            "description": "Total execution duration in milliseconds"
          },
          "error": {
            "type": "string",
            "nullable": true,
            "description": "Error message if execution failed"
          },
          "stepExecutions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StepExecution"
            },
            "description": "Details of each step execution"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Record creation timestamp"
          }
        }
      },
      "StepExecution": {
        "type": "object",
        "properties": {
          "stepName": {
            "type": "string",
            "description": "Display name of the step"
          },
          "stepPath": {
            "type": "string",
            "description": "File path to the step"
          },
          "status": {
            "type": "string",
            "enum": ["completed", "error"],
            "description": "Step execution status"
          },
          "duration": {
            "type": "integer",
            "description": "Step execution duration in milliseconds"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Step start time"
          },
          "endedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Step end time"
          },
          "inputData": {
            "type": "object",
            "nullable": true,
            "description": "Input data for the step"
          },
          "outputData": {
            "type": "object",
            "nullable": true,
            "description": "Output data from the step"
          },
          "error": {
            "type": "string",
            "nullable": true,
            "description": "Error message if step failed"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Workflow Definition",
      "description": "Operations for managing workflow definitions"
    },
    {
      "name": "Workflow Execution",
      "description": "Operations for executing and tracking workflow executions"
    },
    {
      "name": "Analytics",
      "description": "Analytics and reporting operations"
    },
    {
      "name": "Settings",
      "description": "Service configuration and settings"
    },
    {
      "name": "Service Status",
      "description": "Service status and health checks"
    }
  ]
}
